<!DOCTYPE html>
<html lang="en" dir="ltr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Visual Journal | Picnique Luxury Gallery</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: '#D4AF37',
                        secondary: '#FFF9F5',
                        accent: '#F8D7DA',
                    },
                    fontFamily: {
                        serif: ['Playfair Display', 'serif'],
                        sans: ['Inter', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="styles.css">
    <link rel="icon" type="image/svg+xml" href="assets/favicon.svg">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;600;900&display=swap" rel="stylesheet">
    <style>
        .gallery-item {
            transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .gallery-item:hover img {
            transform: scale(1.1) rotate(1deg);
        }
        .filter-btn.active {
            background: #D4AF37;
            color: white;
            border-color: #D4AF37;
        }
    </style>
</head>
<body class="bg-secondary dark:bg-[#1A1A1A] text-text-dark dark:text-text-light pt-24 font-sans">

    <!-- Header (Gallery active) -->
    <header class="fixed top-0 w-full z-50 transition-all duration-300">
        <nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between font-serif">
            <a href="index.html" class="flex items-center space-x-2 group">
                <img src="assets/favicon.svg" alt="Logo" class="h-10 w-10 object-contain">
                <span class="font-serif text-2xl font-bold text-primary tracking-tight logo-text">Picnique</span>
            </a>
            <div class="hidden lg:flex items-center space-x-10 text-sm font-bold uppercase tracking-widest font-sans">
                <a href="index.html" class="hover:text-primary transition-all font-sans">Home 1</a>
                <a href="home2.html" class="hover:text-primary transition-all font-sans">Home 2</a>
                <a href="about.html" class="hover:text-primary transition-all font-sans">About</a>
                <a href="gallery.html" class="text-primary relative after:content-[''] after:absolute after:-bottom-2 after:left-0 after:w-full after:h-[1px] after:bg-primary transition-all font-sans">Gallery</a>
                <a href="contact.html" class="hover:text-primary transition-all font-sans">Contact</a>
            </div>
            <div class="flex items-center space-x-4 lg:space-x-6">
                <div class="hidden lg:flex items-center space-x-4 border-r border-gray-200 dark:border-white/10 pr-6 mr-2 font-sans">
                    <a href="signup.html" class="px-5 py-2 bg-primary text-white text-[10px] font-bold uppercase tracking-[0.2em] rounded-full hover:shadow-lg transition-all">Sign Up</a>
                    <a href="dashboard.html" class="text-xs font-bold uppercase tracking-widest hover:text-primary transition-all ml-4">Dashboard</a>
                </div>
                <button id="theme-toggle" class="p-2 hover:text-primary transition-colors"></button>
                <button id="rtl-toggle" class="px-3 py-1 text-xs border border-primary text-primary rounded-full uppercase font-semibold">RTL</button>
                <button id="menu-btn" class="lg:hidden p-2">
                    <svg class="w-8 h-8 font-sans" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
                </button>
            </div>
        </nav>
    </header>

    <!-- Mobile Navigation Overlay -->
    <div id="mobile-menu" class="fixed inset-0 bg-white/95 dark:bg-black/95 z-[60] flex flex-col items-center justify-center space-y-8 text-2xl font-serif translate-x-full transition-transform duration-500 lg:hidden">
        <button id="menu-close" class="absolute top-8 right-8 p-2">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
        <a href="index.html" class="mobile-link">Home 1</a>
        <a href="home2.html" class="mobile-link">Home 2</a>
        <a href="about.html" class="mobile-link">About</a>
        <a href="gallery.html" class="mobile-link text-primary">Gallery</a>
        <a href="contact.html" class="mobile-link">Contact</a>
        <div class="pt-8 flex flex-col items-center space-y-4">
            <a href="signup.html" class="px-8 py-3 bg-primary text-white rounded-full text-lg font-sans w-full text-center font-sans">Sign Up</a>
            <a href="dashboard.html" class="text-primary text-lg font-sans hover:underline">Dashboard</a>
        </div>
    </div>

    <!-- Hero Section -->
    <section class="py-24 px-6 bg-secondary dark:bg-[#151515] relative overflow-hidden">
        <div class="max-w-7xl mx-auto text-center relative z-10">
            <h6 class="text-xs uppercase tracking-[0.6em] text-primary font-black mb-6">Our Portfolio</h6>
            <h1 class="text-6xl md:text-8xl font-serif mb-8 italic">The Lookbook</h1>
            <p class="text-gray-500 dark:text-gray-400 max-w-2xl mx-auto text-lg leading-relaxed">
                Step into a world of curated beauty. Each frame captures an intentional moment of joy, styling, and connection.
            </p>
        </div>
        <div class="absolute top-0 left-0 w-full h-full opacity-5 pointer-events-none bg-[url('assets/bg-pattern.png')]"></div>
    </section>

    <!-- Gallery Controls -->
    <div class="py-12 px-6 flex flex-wrap justify-center gap-4 bg-white dark:bg-[#1A1A1A] sticky top-20 z-40 border-b border-gray-100 dark:border-white/5">
        <button class="filter-btn active px-8 py-2 border border-gray-200 dark:border-white/10 rounded-full text-xs font-bold uppercase tracking-widest transition-all">All</button>
        <button class="filter-btn px-8 py-2 border border-gray-200 dark:border-white/10 rounded-full text-xs font-bold uppercase tracking-widest transition-all hover:border-primary">Proposals</button>
        <button class="filter-btn px-8 py-2 border border-gray-200 dark:border-white/10 rounded-full text-xs font-bold uppercase tracking-widest transition-all hover:border-primary">Boho</button>
        <button class="filter-btn px-8 py-2 border border-gray-200 dark:border-white/10 rounded-full text-xs font-bold uppercase tracking-widest transition-all hover:border-primary">Sunset</button>
        <button class="filter-btn px-8 py-2 border border-gray-200 dark:border-white/10 rounded-full text-xs font-bold uppercase tracking-widest transition-all hover:border-primary">Floral</button>
    </div>

    <!-- Masonry Gallery -->
    <section class="py-20 px-6 bg-white dark:bg-[#1A1A1A]">
        <div class="max-w-7xl mx-auto columns-1 md:columns-2 lg:columns-3 gap-8 space-y-8">
            <!-- Item 1 -->
            <div class="gallery-item relative overflow-hidden rounded-[2rem] group cursor-pointer">
                <img src="assets/theme-boho.png" class="w-full h-auto transition-transform duration-700">
                <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col justify-end p-10 text-white">
                    <span class="text-[10px] uppercase tracking-[0.3em] text-primary font-bold mb-2">Boho Chic</span>
                    <h3 class="text-2xl font-serif">Wildflower Dreams</h3>
                </div>
            </div>
            <!-- Item 2 -->
            <div class="gallery-item relative overflow-hidden rounded-[2rem] group cursor-pointer">
                <img src="assets/home2-hero.png" class="w-full h-auto transition-transform duration-700">
                <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col justify-end p-10 text-white">
                    <span class="text-[10px] uppercase tracking-[0.3em] text-primary font-bold mb-2">Proposal</span>
                    <h3 class="text-2xl font-serif">Island Sunset</h3>
                </div>
            </div>
            <!-- Item 3 -->
            <div class="gallery-item relative overflow-hidden rounded-[2rem] group cursor-pointer">
                <img src="assets/bg-pattern.png" class="w-full h-64 object-cover transition-transform duration-700">
                <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col justify-end p-10 text-white">
                    <span class="text-[10px] uppercase tracking-[0.3em] text-primary font-bold mb-2">Texture</span>
                    <h3 class="text-2xl font-serif">The Artisanal Base</h3>
                </div>
            </div>
            <!-- Item 4 (Placeholder) -->
            <div class="gallery-item relative overflow-hidden rounded-[2rem] group cursor-pointer aspect-video md:aspect-auto">
                <img src="assets/about-hero.png" class="w-full h-auto transition-transform duration-700">
                <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col justify-end p-10 text-white">
                    <span class="text-[10px] uppercase tracking-[0.3em] text-primary font-bold mb-2">Events</span>
                    <h3 class="text-2xl font-serif">Brunch in the Oaks</h3>
                </div>
            </div>
            <!-- Item 5 -->
            <div class="gallery-item relative overflow-hidden rounded-[2rem] group cursor-pointer">
                <img src="assets/theme-boho.png" class="w-full h-auto transition-transform duration-700">
                <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col justify-end p-10 text-white">
                    <span class="text-[10px] uppercase tracking-[0.3em] text-primary font-bold mb-2">Floral</span>
                    <h3 class="text-2xl font-serif">Peony Paradiso</h3>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-[#2D241E] text-white py-20 px-6">
        <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12 text-gray-400 text-sm">
            <div class="space-y-6">
                <a href="index.html" class="flex items-center space-x-2">
                    <img src="assets/favicon.svg" alt="Logo" class="h-8 w-8">
                    <span class="font-serif text-xl font-bold text-primary tracking-tight">Picnique</span>
                </a>
                <p>Crafting extraordinary moments in nature's most beautiful corners. Luxury redefined through curated picnic experiences.</p>
            </div>
            <div>
                <h4 class="text-white font-serif text-lg mb-6">Explore</h4>
                <a href="about.html" class="block mb-4 hover:text-primary">Our Story</a>
                <a href="gallery.html" class="block mb-4 hover:text-primary">Gallery</a>
                <a href="contact.html" class="block hover:text-primary">Help Center</a>
            </div>
            <div>
                <h4 class="text-white font-serif text-lg mb-6">Concierge</h4>
                <p class="mb-4">+1 (888) PIC-NIQUE</p>
                <p class="mb-4">reservations@picnique.com</p>
                <p>Mon - Sun: 8:00 AM - 10:00 PM</p>
            </div>
            <div>
                <h4 class="text-white font-serif text-lg mb-6">Newsletter</h4>
                <p class="mb-6">Join our waitlist for seasonal themes.</p>
                <form class="flex">
                    <input type="email" placeholder="email address" class="bg-white/5 border border-white/10 py-3 px-4 rounded-l-full w-full outline-none focus:border-primary">
                    <button class="bg-primary text-white px-6 py-3 rounded-r-full hover:bg-white hover:text-primary transition-all">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                    </button>
                </form>
            </div>
        </div>
        <div class="text-center pt-16 uppercase tracking-[0.2em] text-[10px] opacity-30">
            &copy; 2026 Picnique Experiences.
        </div>
    </footer>

    <script src="main.js"></script>
</body>
</html>
